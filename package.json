{
  "name": "agentlease",
  "version": "0.1.0",
  "description": "Local time-boxed permission leases for coding-agent sessions.",
  "type": "module",
  "bin": {
    "agentlease": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm run build && node scripts/pack-smoke.mjs",
    "release:check": "npm test && npm run smoke && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "agent",
    "cli",
    "permissions",
    "policy",
    "lease",
    "ledger"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agentlease.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agentlease/issues"
  },
  "homepage": "https://github.com/rogerchappel/agentlease#readme"
}
